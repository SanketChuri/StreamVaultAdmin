@model List<StreamVaultAdmin.Models.ContentItem>

@{
    ViewData["Title"] = "Catalogue";
    string currentType = ViewBag.CurrentType ?? "";
    string currentSearch = ViewBag.CurrentSearch ?? "";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>StreamVault Catalogue</h1>
        <div class="dropdown">
            <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Add New
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/Catalogue/Create?type=Movie">Movie</a></li>
                <li><a class="dropdown-item" href="/Catalogue/Create?type=Series">Series</a></li>
                <li><a class="dropdown-item" href="/Catalogue/Create?type=Audiobook">Audiobook</a></li>
                <li><a class="dropdown-item" href="/Catalogue/Create?type=MusicAlbum">Music Album</a></li>
            </ul>
        </div>
    </div>

    <form method="get" action="/Catalogue" class="row g-3 mb-4">
        <div class="col-md-4">
            <!select name="type" class="form-select">
                <option value="">All Types</option>
                <!option value="Movie"      @(currentType == "Movie"      ? "selected" : "")>Movie</!option>
                <!option value="Series"     @(currentType == "Series"     ? "selected" : "")>Series</!option>
                <!option value="Audiobook"  @(currentType == "Audiobook"  ? "selected" : "")>Audiobook</!option>
                <!option value="MusicAlbum" @(currentType == "MusicAlbum" ? "selected" : "")>Music Album</!option>
            </!select>
        </div>
        <div class="col-md-6"> 
            <input type="text" name="search" class="form-control"
                placeholder="Search by title..."
                value="@currentSearch" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No content found.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Genre</th>
                    <th>Age Rating</th>
                    <th>Release Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>
                            <span class="badge bg-primary">@item.ContentType</span>
                        </td>
                        <td>@item.Genre</td>
                        <td>@item.AgeRating</td>
                        <td>@item.ReleaseDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/Catalogue/Edit/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/Catalogue/Delete/@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>