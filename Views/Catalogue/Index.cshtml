@model List<StreamVaultAdmin.Models.ContentItem>

@{
    ViewData["Title"] = "Catalogue";
    string currentType = ViewBag.CurrentType as string ?? "";
    string currentSearch = ViewBag.CurrentSearch as string ?? "";
    string currentSort = ViewBag.CurrentSort as string ?? "";
}

<h2>Catalogue</h2>
<p>Current Sort: @currentSort</p>
@if (TempData["Success"] != null)
{
    <p style="color:green;">@TempData["Success"]</p>
}

<form method="get" action="/Catalogue">
    <input type="hidden" name="sortBy" value="@currentSort" />

    <!select name="type">
        <option value="">All Types</option>
        <!option value="Movie"      @(currentType == "Movie"      ? "selected" : "")>Movie</!option>
        <!option value="Series"     @(currentType == "Series"     ? "selected" : "")>Series</!option>
        <!option value="Audiobook"  @(currentType == "Audiobook"  ? "selected" : "")>Audiobook</!option>
        <!option value="MusicAlbum" @(currentType == "MusicAlbum" ? "selected" : "")>Music Album</!option>
    </!select>

    <input type="text" name="search" placeholder="Search by title..." value="@currentSearch" />
    <button type="submit">Search</button>
</form>

<p>
    Add new:
    <select onchange="if(this.value) window.location.href=this.value">
        <option value="">Select type...</option>
        <option value="/Catalogue/Create?type=Movie">Movie</option>
        <option value="/Catalogue/Create?type=Series">Series</option>
        <option value="/Catalogue/Create?type=Audiobook">Audiobook</option>
        <option value="/Catalogue/Create?type=MusicAlbum">Music Album</option>
    </select>
</p>

<p>Showing @Model.Count() item(s)</p>

@if (!Model.Any())
{
    <p>No content found.</p>
}
else
{
    <table border="1" cellpadding="6">
        <tr>
            @* <th>
                <a href="/Catalogue?sortBy=@(currentSort == "title" ? "title_desc" : "title")&type=@currentType&search=@currentSearch">Title</a>
                @if (currentSort == "title") { <text>▲</text> }
                @if (currentSort == "title_desc") { <text>▼</text> }
            </th>
            <th>
                <a href="/Catalogue?sortBy=@(currentSort == "type" ? "type_desc" : "type")&type=@currentType&search=@currentSearch">Type</a>
                @if (currentSort == "type") { <text>▲</text> }
                @if (currentSort == "type_desc") { <text>▼</text> }
            </th>
            <th>Genre</th>
            <th>Age Rating</th>
            <th>
                <a href="/Catalogue?sortBy=@(currentSort == "date" ? "date_desc" : "date")&type=@currentType&search=@currentSearch">Release Date</a>
                @if (currentSort == "date") { <text>▲</text> }
                @if (currentSort == "date_desc") { <text>▼</text> }
            </th>
            <th>Actions</th> *@
            <th>
                <a href="/Catalogue?sortBy=@(currentSort == "title" ? "title_desc" : "title")&amp;type=@currentType&amp;search=@currentSearch">Title</a>
                @if (currentSort == "title") { <text>▲</text> }
                @if (currentSort == "title_desc") { <text>▼</text> }
            </th>
            <th>
                <a href="/Catalogue?sortBy=@(currentSort == "contenttype" ? "contenttype_desc" : "contenttype")&amp;type=@currentType&amp;search=@currentSearch">Type</a>
                @if (currentSort == "contenttype") { <text>▲</text> }
                @if (currentSort == "contenttype_desc") { <text>▼</text> }
            </th>
            <th>Genre</th>
            <th>Age Rating</th>
            <th>
                <a href="/Catalogue?sortBy=@(currentSort == "date" ? "date_desc" : "date")&amp;type=@currentType&amp;search=@currentSearch">Release Date</a>
                @if (currentSort == "date") { <text>▲</text> }
                @if (currentSort == "date_desc") { <text>▼</text> }
            </th>
            <th>Actions</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.ContentType</td>
                <td>@item.Genre</td>
                <td>@item.AgeRating</td>
                <td>@item.ReleaseDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a href="/Catalogue/Edit/@item.Id?type=@item.ContentType">Edit</a> |
                    <a href="/Catalogue/Delete/@item.Id?type=@item.ContentType">Delete</a>
                </td>
            </tr>
        }
    </table>
}