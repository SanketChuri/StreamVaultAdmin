@model List<StreamVaultAdmin.Models.ContentItem>

@{
    ViewData["Title"] = "Catalogue";
    string currentType = ViewBag.CurrentType as string ?? "";
    string currentSearch = ViewBag.CurrentSearch as string ?? "";
}

<h2>Catalogue</h2>

<form method="get" action="/Catalogue">
    <select name="type">
        <option value="">All Types</option>
        <!option value="Movie"      @(currentType == "Movie"      ? "selected" : "")>Movie</!option>
        <!option value="Series"     @(currentType == "Series"     ? "selected" : "")>Series</!option>
        <!option value="Audiobook"  @(currentType == "Audiobook"  ? "selected" : "")>Audiobook</!option>
        <!option value="MusicAlbum" @(currentType == "MusicAlbum" ? "selected" : "")>Music Album</!option>
    </select>
    <input type="text" name="search" placeholder="Search by title..." value="@currentSearch" />
    <button type="submit">Search</button>
</form>

<p>
    Add new:
    <select onchange="if(this.value) window.location.href=this.value">
        <option value="">Select type...</option>
        <option value="/Catalogue/Create?type=Movie">Movie</option>
        <option value="/Catalogue/Create?type=Series">Series</option>
        <option value="/Catalogue/Create?type=Audiobook">Audiobook</option>
        <option value="/Catalogue/Create?type=MusicAlbum">Music Album</option>
    </select>
</p>

@if (!Model.Any())
{
    <p>No content found.</p>
}
else
{
    <table border="1" cellpadding="6">
        <tr>
            <th>Title</th>
            <th>Type</th>
            <th>Genre</th>
            <th>Age Rating</th>
            <th>Release Date</th>
            <th>Actions</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.ContentType</td>
                <td>@item.Genre</td>
                <td>@item.AgeRating</td>
                <td>@item.ReleaseDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a href="/Catalogue/Edit/@item.Id?type=@item.ContentType">Edit</a> |
                    <a href="/Catalogue/Delete/@item.Id?type=@item.ContentType">Delete</a>
                </td>
            </tr>
        }
    </table>
}