@model StreamVaultAdmin.Models.ContentItem

@{
    ViewData["Title"] = "Delete " + Model.Title;
}

<div class="container mt-4">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Confirm Delete</h4>
        </div>
        <div class="card-body">
            <p class="lead">Are you sure you want to delete this item?</p>

            <table class="table table-bordered w-50">
                <tr>
                    <th>Title</th>
                    <td>@Model.Title</td>
                </tr>
                <tr>
                    <th>Type</th>
                    <td>
                        <span class="badge bg-primary">@Model.ContentType</span>
                    </td>
                </tr>
                <tr>
                    <th>Genre</th>
                    <td>@Model.Genre</td>
                </tr>
                <tr>
                    <th>Release Date</th>
                    <td>@Model.ReleaseDate.ToString("dd MMM yyyy")</td>
                </tr>
            </table>

            <div class="mt-3">
                <form method="post" action="/Catalogue/Delete/@Model.Id">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a href="/Catalogue" class="btn btn-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>