@model StreamVaultAdmin.Models.ContentItem

@{
    ViewData["Title"] = "Delete";
}

<h2>Delete</h2>

<p>Are you sure you want to delete this item?</p>

<table border="1" cellpadding="6">
    <tr>
        <th>Title</th>
        <td>@Model.Title</td>
    </tr>
    <tr>
        <th>Type</th>
        <td>@Model.ContentType</td>
    </tr>
    <tr>
        <th>Genre</th>
        <td>@Model.Genre</td>
    </tr>
    <tr>
        <th>Age Rating</th>
        <td>@Model.AgeRating</td>
    </tr>
    <tr>
        <th>Release Date</th>
        <td>@Model.ReleaseDate.ToString("dd MMM yyyy")</td>
    </tr>
</table>

<br />

<form method="post" action="/Catalogue/Delete/@Model.Id">
    <button type="submit">Yes, Delete</button>
    <a href="/Catalogue">Cancel</a>
</form>