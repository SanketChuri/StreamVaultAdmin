@{
    ViewData["Title"] = "Add New";
    string type = ViewBag.Type as string ?? "";
}

<h2>Add New @type</h2>

<a href="/Catalogue">Back to Catalogue</a>

<br /><br />

<form method="post" action="/Catalogue/Create?type=@type">

    <h4>General</h4>

    <p>
        <label>Title</label><br />
        <input type="text" name="Title" required />
    </p>

    <p>
        <label>Description</label><br />
        <textarea name="Description" rows="3" cols="50" required></textarea>
    </p>

    <p>
        <label>Release Date</label><br />
        <input type="date" name="ReleaseDate" required />
    </p>

    <p>
        <label>Age Rating</label><br />
        <select name="AgeRating" required>
            <option value="">Select...</option>
            <option>U</option>
            <option>PG</option>
            <option>12</option>
            <option>12A</option>
            <option>15</option>
            <option>18</option>
        </select>
    </p>

    <p>
        <label>Genre</label><br />
        <input type="text" name="Genre" required />
    </p>

    <h4>@type Details</h4>

    @if (type == "Movie")
    {
        <p>
            <label>Duration (minutes)</label><br />
            <input type="number" name="Duration" min="1" required />
        </p>
        <p>
            <label>Director</label><br />
            <input type="text" name="Director" required />
        </p>
    }
    else if (type == "Series")
    {
        <p>
            <label>Number of Seasons</label><br />
            <input type="number" name="NumberOfSeasons" min="1" required />
        </p>
        <p>
            <label>Total Episodes</label><br />
            <input type="number" name="TotalEpisodes" min="1" required />
        </p>
    }
    else if (type == "Audiobook")
    {
        <p>
            <label>Author</label><br />
            <input type="text" name="Author" required />
        </p>
        <p>
            <label>Narrator</label><br />
            <input type="text" name="Narrator" required />
        </p>
        <p>
            <label>Duration (minutes)</label><br />
            <input type="number" name="Duration" min="1" required />
        </p>
    }
    else if (type == "MusicAlbum")
    {
        <p>
            <label>Artist</label><br />
            <input type="text" name="Artist" required />
        </p>
        <p>
            <label>Track Count</label><br />
            <input type="number" name="TrackCount" min="1" required />
        </p>
        <p>
            <label>Record Label</label><br />
            <input type="text" name="RecordLabel" required />
        </p>
    }

    <p>
        <button type="submit">Save</button>
        <a href="/Catalogue">Cancel</a>
    </p>

</form>