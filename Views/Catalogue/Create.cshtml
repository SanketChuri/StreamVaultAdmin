@{
    ViewData["Title"] = "Add New " + ViewBag.Type;
    string type = ViewBag.Type;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Add New @type</h1>
        <a href="/Catalogue" class="btn btn-secondary">Back to Catalogue</a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" action="/Catalogue/Create?type=@type">

                <h5 class="mb-3">General Information</h5>

                <div class="mb-3">
                    <label class="form-label">Title *</label>
                    <input type="text" name="Title" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description *</label>
                    <textarea name="Description" class="form-control" rows="3" required></textarea>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Release Date *</label>
                        <input type="date" name="ReleaseDate" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Age Rating *</label>
                        <select name="AgeRating" class="form-select" required>
                            <option value="">Select...</option>
                            <option>U</option>
                            <option>PG</option>
                            <option>12</option>
                            <option>12A</option>
                            <option>15</option>
                            <option>18</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Genre *</label>
                        <input type="text" name="Genre" class="form-control" required />
                    </div>
                </div>

                <hr />
                <h5 class="mb-3">@type Details</h5>

                @if (type == "Movie")
                {
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Duration (minutes) *</label>
                            <input type="number" name="Duration" class="form-control" min="1" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Director *</label>
                            <input type="text" name="Director" class="form-control" required />
                        </div>
                    </div>
                }
                else if (type == "Series")
                {
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Number of Seasons *</label>
                            <input type="number" name="NumberOfSeasons" class="form-control" min="1" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Total Episodes *</label>
                            <input type="number" name="TotalEpisodes" class="form-control" min="1" required />
                        </div>
                    </div>
                }
                else if (type == "Audiobook")
                {
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Author *</label>
                            <input type="text" name="Author" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Narrator *</label>
                            <input type="text" name="Narrator" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Duration (minutes) *</label>
                            <input type="number" name="Duration" class="form-control" min="1" required />
                        </div>
                    </div>
                }
                else if (type == "MusicAlbum")
                {
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Artist *</label>
                            <input type="text" name="Artist" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Track Count *</label>
                            <input type="number" name="TrackCount" class="form-control" min="1" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Record Label *</label>
                            <input type="text" name="RecordLabel" class="form-control" required />
                        </div>
                    </div>
                }

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Save</button>
                    <a href="/Catalogue" class="btn btn-secondary ms-2">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>