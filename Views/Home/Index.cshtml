@{
    ViewData["Title"] = "StreamVault Admin";
}

<div style="text-align:center; margin-top:80px;">
    <h1>Welcome to StreamVault Admin</h1>
    <p>This is the internal admin tool for managing the StreamVault streaming platform catalogue.</p>
    <p>From here you can manage all content including Movies, Series, Audiobooks and Music Albums.</p>
    <br />
    <p>To get started click the button below or use the Catalogue link in the navigation bar above or click the "View Catalogue" link.</p>
    <br />
    <a href="/Catalogue" style="font-size:18px;">View Catalogue</a>
    <br /><br />
    <div style="margin-top:30px; text-align:left; display:inline-block;">
        <p><strong>What you can do:</strong></p>
        <p>📋 View all content in the catalogue</p>
        <p>🔍 Search by title or filter by content type</p>
        <p>➕ Add new Movies, Series, Audiobooks or Music Albums</p>
        <p>✏️ Edit existing content</p>
        <p>🗑️ Delete content you no longer need</p>
    </div>
</div>